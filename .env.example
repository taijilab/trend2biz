# Trend2Biz 配置模板
# 复制为 .env 后修改对应值

# 数据库连接（默认 SQLite，可切换 PostgreSQL）
DATABASE_URL=sqlite:///./trend2biz.db
# PostgreSQL 示例:
# DATABASE_URL=postgresql://user:password@localhost:5432/trend2biz

# GitHub Personal Access Token（可选，但推荐设置）
# 未设置时 GitHub API 限速 60 req/h；设置后 5000 req/h
# 在 https://github.com/settings/tokens 生成（只需 public_repo read 权限）
GITHUB_TOKEN=

# Anthropic API Key（可选，设置后用 Claude Haiku 生成更丰富的中文项目介绍）
# 在 https://console.anthropic.com 获取
# 未设置时降级到 MyMemory 免费翻译
ANTHROPIC_API_KEY=

# 应用名称
APP_NAME=Trend2Biz API

# API 路径前缀
API_PREFIX=/api/v1
